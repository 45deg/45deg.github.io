<!DOCTYPE html>
<html lang="{{ lang }}">

<head>
    {% set siteUrl = homepage.site_url %}
    {% set siteName = homepage.title %}
    {% set pageTitle = homepage.seo_title | locale(lang) %}
    {% set pageDescription = homepage.description | locale(lang) %}
    {% set canonicalPath = "/" if lang == "ja" else "/index_en.html" %}
    {% set canonicalUrl = canonicalPath | absoluteUrl(siteUrl) %}
    {% set alternateJaUrl = "/" | absoluteUrl(siteUrl) %}
    {% set alternateEnUrl = "/index_en.html" | absoluteUrl(siteUrl) %}
    {% set ogImageUrl = homepage.og_image | absoluteUrl(siteUrl) %}
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ pageTitle }}</title>
    <meta name="description" content="{{ pageDescription }}">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="{{ canonicalUrl }}">
    <link rel="alternate" hreflang="ja" href="{{ alternateJaUrl }}">
    <link rel="alternate" hreflang="en" href="{{ alternateEnUrl }}">
    <link rel="alternate" hreflang="x-default" href="{{ alternateJaUrl }}">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="{{ siteName }}">
    <meta property="og:title" content="{{ pageTitle }}">
    <meta property="og:description" content="{{ pageDescription }}">
    <meta property="og:url" content="{{ canonicalUrl }}">
    <meta property="og:image" content="{{ ogImageUrl }}">
    <meta property="og:locale" content="{{ 'ja_JP' if lang == 'ja' else 'en_US' }}">
    <meta property="og:locale:alternate" content="{{ 'en_US' if lang == 'ja' else 'ja_JP' }}">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ pageTitle }}">
    <meta name="twitter:description" content="{{ pageDescription }}">
    <meta name="twitter:image" content="{{ ogImageUrl }}">
    <link rel="stylesheet" href="{{ './style.css' | localPath(lang) }}">
    <script type="application/ld+json">
        {{ {
            "@context": "https://schema.org",
            "@type": "WebSite",
            "name": siteName,
            "url": canonicalUrl,
            "description": pageDescription,
            "inLanguage": lang,
            "author": {
                "@type": "Person",
                "name": "zakuro",
                "url": homepage.profile_url
            }
        } | json | safe }}
    </script>
</head>

<body>

    <header>
        <h1>{{ homepage.title }}</h1>
        <nav class="language-switch" aria-label="Language">
            {% if lang == "ja" %}
            <a class="is-active" href="./" aria-current="page">日本語</a>
            <a href="{{ alternateUrl }}">English</a>
            {% else %}
            <a href="{{ alternateUrl }}">日本語</a>
            <a class="is-active" href="./index_en.html" aria-current="page">English</a>
            {% endif %}
        </nav>
    </header>

    <section class="about-section">
        <h2>About</h2>
        <p>{{ homepage.about | locale(lang) }} <a href="{{ homepage.profile_url }}">X</a></p>
    </section>

    <div class="page-flow">
        <main class="main">
            <section>
                <h2>Works</h2>
                <div class="work-filters" id="work-filter-tags" aria-label="Work filters">
                    {% for filter in homepage.filters %}
                    <button class="tag-filter{% if filter.collapsible %} is-collapsible{% endif %}{% if loop.first %} is-active{% endif %}" type="button" data-filter="{{ filter.key }}" aria-pressed="{{ 'true' if loop.first else 'false' }}">{{ filter.label | locale(lang) }} ({{ homepage.works | countByFilter(filter.key) }})</button>
                    {% endfor %}
                </div>
                <div class="works-grid" id="works-grid">
                    {% for work in homepage.works %}
                    <article class="card{% if work.featured %} is-featured{% endif %}" data-featured="{{ 'true' if work.featured else 'false' }}" data-tags="{{ work.tags | join(',') }}">
                        <a class="card-link" href="{{ work.href | localPath(lang) }}" aria-label="{{ work.title | locale(lang) }} {{ work.year }}"></a>
                        <div class="card-img-wrapper">
                            {% if work.image %}
                            <img src="{{ work.image.src | localPath(lang) }}" alt="{{ work.image.alt | locale(lang) }}">
                            {% else %}
                            <div class="placeholder-img {{ work.placeholder.class }}" data-emoji="{{ work.placeholder.emoji }}"></div>
                            {% endif %}
                        </div>
                        <div class="card-content">
                            <h3 class="card-title"><strong>{{ work.title | locale(lang) }}</strong> <span class="text-muted">({{ work.year }})</span></h3>
                            <p class="card-desc">{{ work.description_html | locale(lang) | safe }}</p>
                            <div class="card-tags" aria-label="{{ 'タグ' if lang == 'ja' else 'Tags' }}">
                                {% if work.featured %}<span class="featured-tag">Featured</span>{% endif %}
                                {% for tag in work.tags %}<span>{{ tag }}</span>{% endfor %}
                            </div>
                        </div>
                    </article>
                    {% endfor %}
                </div>
            </section>
        </main>
    </div>

    <script>
        (() => {
            const filterRoot = document.querySelector("#work-filter-tags");
            const cards = [...document.querySelectorAll("#works-grid .card")];
            if (!filterRoot || !cards.length) return;

            const filterButtons = [...filterRoot.querySelectorAll("[data-filter]")];
            const applyFilter = (key) => {
                for (const button of filterButtons) {
                    const isActive = button.dataset.filter === key;
                    button.classList.toggle("is-active", isActive);
                    button.setAttribute("aria-pressed", String(isActive));
                }

                for (const card of cards) {
                    const tags = card.dataset.tags.split(",").filter(Boolean);
                    const isVisible = key === "all" ||
                        (key === "featured" && card.dataset.featured === "true") ||
                        tags.includes(key[0].toUpperCase() + key.slice(1));
                    card.hidden = !isVisible;
                }
            };

            filterRoot.addEventListener("click", (event) => {
                const filterButton = event.target.closest("[data-filter]");
                if (filterButton) {
                    applyFilter(filterButton.dataset.filter);
                }
            });
        })();
    </script>
</body>

</html>
